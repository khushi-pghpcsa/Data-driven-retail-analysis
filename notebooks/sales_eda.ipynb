# =========================
# 1. IMPORT LIBRARIES
# =========================
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

sns.set(style="whitegrid")

# =========================
# 2. LOAD DATA
# =========================
df = pd.read_csv("../data/supermarket_sales.csv")

print("Shape:", df.shape)
df.head()

# =========================
# 3. DATA CLEANING
# =========================
df['Date'] = pd.to_datetime(df['Date'])
df['Time'] = pd.to_datetime(df['Time'])

df['Month'] = df['Date'].dt.month_name()
df['Hour'] = df['Time'].dt.hour

print(df.isnull().sum())

# =========================
# 4. BASIC STATS
# =========================
df.describe()

# =========================
# 5. SALES BY CITY
# =========================
plt.figure(figsize=(6,4))
sns.barplot(x='City', y='Total', data=df, estimator=sum)
plt.title("Total Sales by City")
plt.savefig("../docs/images/sales_by_city.png")
plt.show()

# =========================
# 6. SALES BY PRODUCT LINE
# =========================
plt.figure(figsize=(8,5))
sns.barplot(x='Product line', y='Total', data=df, estimator=sum)
plt.xticks(rotation=45)
plt.title("Sales by Product Line")
plt.savefig("../docs/images/product_sales.png")
plt.show()

# =========================
# 7. GENDER SPENDING
# =========================
plt.figure(figsize=(6,4))
sns.boxplot(x='Gender', y='Total', data=df)
plt.title("Spending by Gender")
plt.savefig("../docs/images/gender_spending.png")
plt.show()

# =========================
# 8. PAYMENT METHODS
# =========================
plt.figure(figsize=(5,5))
df['Payment'].value_counts().plot(kind='pie', autopct='%1.1f%%')
plt.title("Payment Distribution")
plt.savefig("../docs/images/payment.png")
plt.show()

# =========================
# 9. SALES BY HOUR
# =========================
plt.figure(figsize=(8,4))
sns.lineplot(x='Hour', y='Total', data=df)
plt.title("Sales Trend by Hour")
plt.savefig("../docs/images/sales_hour.png")
plt.show()

# =========================
# 10. CORRELATION HEATMAP
# =========================
plt.figure(figsize=(8,6))
sns.heatmap(df.corr(numeric_only=True), annot=True, cmap="coolwarm")
plt.title("Correlation Heatmap")
plt.savefig("../docs/images/correlation.png")
plt.show()
